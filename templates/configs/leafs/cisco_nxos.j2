!
! {{ name }} Configuration
!
hostname {{ name }}
!
feature ospf
feature bgp
feature interface-vlan
feature lacp
feature vpc
feature lldp
!
{%- include 'common/cisco_nxos_vpc.j2' %}
! VLANs
{%- for vlan in vlans %}
vlan {{ vlan.vlan_id }}
  name {{ vlan.name }}
!
{%- endfor %}
!
{%- if acls %}
! Zero-Trust ACLs (one per segment VLAN — inbound on SVI)
!
{%- for acl in acls %}
ip access-list {{ acl.name }}
{%- for rule in acl.rules %}
{%- if rule.src_zone or rule.dst_zone %}
  remark Zone: {{ rule.src_zone or 'any' }} -> {{ rule.dst_zone or 'any' }}
{%- endif %}
  {{ rule.seq }} {{ rule.action }} {{ rule.protocol }} {{ rule.src }} {{ rule.dst -}}
{%- if rule.dst_port %} {{ rule.dst_port }}{% endif -%}
{%- if rule.log %} log{% endif -%}
{%- if rule.name %} ! {{ rule.name }}{% endif %}
{%- endfor %}
!
{%- endfor %}
{%- endif %}
!
! Interfaces
{%- for interface in interfaces if interface.role != 'mlag-peer' %}
interface {{ interface.name }}
{%- if interface.status == 'active' %}
  no shutdown
{%- endif %}
{%- include 'common/cisco_nxos_interface_ip.j2' %}
{%- if interface.vlans %}
  switchport
  switchport mode access
  switchport access vlan {{ interface.vlans[0] }}
{%- endif %}
{%- if interface.get('ospf') %}
  ip ospf area {{ interface.ospf.area }}
{%- endif %}
!
{%- endfor %}
!
! OSPF Configuration
{% include 'common/cisco_nxos_ospf.j2' %}
!
! BGP Configuration
{% include 'common/cisco_nxos_bgp.j2' %}
!
{%- if vxlan and vxlan.enabled %}
!
! VXLAN Configuration (netlab-style multivendor)
!
{%- for feature in vxlan.features %}
feature {{ feature }}
{%- endfor %}
!
interface {{ vxlan.nve_interface }}
{%- if vxlan.vtep.ipv4 %}
  source-interface {{ vxlan.vtep.source_interface }}
{%- endif %}
{%- for mapping in vxlan.l2_vni_mappings %}
  member vni {{ mapping.vni }}
    {%- if vxlan.evpn and vxlan.evpn.enabled %}
    ingress-replication protocol bgp
    {%- elif vxlan.flooding == "static" and vxlan.remote_vteps %}
    ingress-replication protocol static
      peer-list {{ vxlan.remote_vteps | join(' ') }}
    {%- endif %}
{%- endfor %}
  no shutdown
!
{%- if vxlan.evpn and vxlan.evpn.enabled %}
!
! EVPN Configuration
!
evpn
{%- for mapping in vxlan.l2_vni_mappings %}
  vni {{ mapping.vni }} l2
    rd {{ vxlan.evpn.rd_format }}
    route-target import {{ bgp[0].local_as.asn }}:{{ mapping.vni }}
    route-target export {{ bgp[0].local_as.asn }}:{{ mapping.vni }}
{%- endfor %}
!
{%- endif %}
!
! VLAN to VNI mapping
!
{%- for mapping in vxlan.l2_vni_mappings %}
vlan {{ mapping.vlan_id }}
  vn-segment {{ mapping.vni }}
{%- endfor %}
{%- endif %}
!
! Route-maps
route-map RM-CONN-2-BGP permit 10
  match interface loopback0
!
{%- if vlans %}
! VLAN SVI Configuration
!
{%- for vlan in vlans %}
{%- if vlan.gateway_ip or vlan.gateway_ipv6 %}
{%- set ns = namespace(acl_name=None) %}
{%- for acl in acls %}
{%- if acl.vlan_id == vlan.vlan_id %}
{%- set ns.acl_name = acl.name %}
{%- endif %}
{%- endfor %}
interface Vlan{{ vlan.vlan_id }}
  description {{ vlan.name }}
{%- if vlan.vrf %}
  vrf member {{ vlan.vrf }}
{%- endif %}
{%- if vlan.gateway_ip %}
  ip address {{ vlan.gateway_ip }}
{%- endif %}
{%- if vlan.gateway_ipv6 %}
  ipv6 address {{ vlan.gateway_ipv6 }}
{%- endif %}
  no shutdown
{%- if ns.acl_name %}
  ip access-group {{ ns.acl_name }} in
{%- endif %}
!
{%- endif %}
{%- endfor %}
{%- endif %}
!
{%- if vrf_gateways %}
!
! VRF Default Routes — firewall gateway per namespace (Option A: FW as inter-VRF router)
!
{%- for vrf, nexthop in vrf_gateways.items() %}
ip route 0.0.0.0/0 {{ nexthop }} vrf {{ vrf }}
{%- endfor %}
!
{%- endif %}
{%- include 'common/cisco_nxos_management.j2' %}
!
! Management
line console
line vty
!
