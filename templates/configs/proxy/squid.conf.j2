#
# Squid Proxy Configuration
# Instance: {{ name }}
# Forwarding method: {{ forwarding_method }}
# Auth type: {{ auth_type }}
#

# ── Core ──────────────────────────────────────────────────────────────────────
http_port {{ proxy_port }}
{% if forwarding_method == 'wccp' %}
wccp2_service dynamic {{ wccp_service_id }}
wccp2_router {{ name }}-edge
wccp2_forwarding_method gre
wccp2_return_method gre
{% endif %}

# ── Access Control ────────────────────────────────────────────────────────────
{% for policy in policies %}
# Policy: {{ policy.name }} (default: {{ policy.default_action }})
{%- for rule in policy.rules %}
{%- if rule.destination_type == 'fqdn' and rule.destination_value %}
acl {{ rule.name | replace('-', '_') }} dstdomain {{ rule.destination_value }}
{%- elif rule.destination_type == 'prefix' and rule.destination_value %}
acl {{ rule.name | replace('-', '_') }} dst {{ rule.destination_value }}
{%- elif rule.destination_type == 'url_category' and rule.url_categories %}
acl {{ rule.name | replace('-', '_') }} dstdomain {% for pattern in rule.url_categories %}{{ pattern }} {% endfor %}

{%- endif %}
{%- endfor %}
{% endfor %}

# ── Rules ─────────────────────────────────────────────────────────────────────
{% for policy in policies %}
{%- for rule in policy.rules %}
{%- if rule.action == 'block' %}
http_access deny {{ rule.name | replace('-', '_') }}
{%- elif rule.action == 'bypass' %}
always_direct allow {{ rule.name | replace('-', '_') }}
{%- else %}
http_access allow {{ rule.name | replace('-', '_') }}
{%- endif %}
{%- endfor %}
{%- if policy.default_action == 'block' %}
http_access deny all
{%- else %}
http_access allow all
{%- endif %}
{% endfor %}

# ── Logging ───────────────────────────────────────────────────────────────────
access_log /var/log/squid/access.log squid
cache_log /var/log/squid/cache.log
